<ui:UXML xmlns:ui="UnityEngine.UIElements"
    xsi="http://www.w3.org/2001/XMLSchema-instance"
    editor="UnityEditor.UIElements"
    noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd">

    <ui:VisualElement name="SetupScreen" class="setup-screen">

        <!-- Header -->
        <ui:VisualElement class="setup-header">
            <ui:Label text="MCP Game Deck" class="setup-title" />
            <ui:Label text="Complete the setup to get started" class="setup-subtitle" />
        </ui:VisualElement>

        <!-- Checklist -->
        <ui:VisualElement name="SetupChecklist" class="setup-checklist">

            <!-- Node.js -->
            <ui:VisualElement name="SetupRow_Node" class="setup-row">
                <ui:Label name="SetupIcon_Node" text="○" class="setup-icon" />
                <ui:VisualElement class="setup-row-content">
                    <ui:Label name="SetupLabel_Node" text="Node.js" class="setup-row-title" />
                    <ui:Label name="SetupDetail_Node" text="Checking..." class="setup-row-detail" />
                </ui:VisualElement>
                <ui:Button name="SetupAction_Node" text="Install" class="setup-action-btn" />
            </ui:VisualElement>

            <!-- Server Build -->
            <ui:VisualElement name="SetupRow_Build" class="setup-row">
                <ui:Label name="SetupIcon_Build" text="○" class="setup-icon" />
                <ui:VisualElement class="setup-row-content">
                    <ui:Label name="SetupLabel_Build" text="Server Build" class="setup-row-title" />
                    <ui:Label name="SetupDetail_Build" text="Checking..." class="setup-row-detail" />
                </ui:VisualElement>
                <ui:Button name="SetupAction_Build" text="Build" class="setup-action-btn" />
            </ui:VisualElement>

            <!-- Claude Code -->
            <ui:VisualElement name="SetupRow_Claude" class="setup-row setup-row-last">
                <ui:Label name="SetupIcon_Claude" text="○" class="setup-icon" />
                <ui:VisualElement class="setup-row-content">
                    <ui:Label name="SetupLabel_Claude" text="Claude Code" class="setup-row-title" />
                    <ui:Label name="SetupDetail_Claude" text="Checking..." class="setup-row-detail" />
                </ui:VisualElement>
                <ui:Button name="SetupAction_Claude" text="Install" class="setup-action-btn" />
            </ui:VisualElement>

        </ui:VisualElement>

        <!-- Build Output Console -->
        <ui:ScrollView name="SetupConsole" class="setup-console" />

        <!-- Footer -->
        <ui:VisualElement class="setup-footer">
            <ui:Button name="SetupRefreshBtn" text="Refresh" class="setup-refresh-btn" />
        </ui:VisualElement>

    </ui:VisualElement>

</ui:UXML>