{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities granted to the main app window. Tauri 2.x requires explicit permissions for frontend APIs (invoke, listen, etc).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "core:window:default",
    "cli:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/*" }]
    }
  ]
}